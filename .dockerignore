# Fix #8 — keep Docker build context tight so a single-file change doesn't
# invalidate the pip cache layer and rebuild from scratch. Pre-fix, all three
# Dockerfiles did `COPY . /app` against a 7000+ file tree (dashboard,
# claude-mem, token-savior, everything-claude-code, audit reports, etc.).

# VCS
.git
.gitignore
.gitattributes

# Python build/run
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
.venv
venv
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov

# Env
.env
.env.*
.env.example

# Docs / audit / planning (not needed at runtime)
audit/
.improvement_proposals/
.remember/
.plan/
.claude/
.windsurf/
.gemini/
.trae/
.cursor/
.codex-plugin/
.claude-plugin/

# Vendored sister projects — these have their own deploys
dashboard/
claude-mem/
token-savior/
everything-claude-code/
awesome-claude-code-subagents/
awesome-claude-skills/
claude-agent-sdk-python/
claude-code-memory-setup/
agency-agents/
agent-orchestrator/
humanizer/
stop-slop/
obsidian/

# Node / JS leftovers (in case any subdir slips through)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.idea
.vscode
*.swp
*.swo
*~
